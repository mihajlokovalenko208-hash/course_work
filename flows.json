    {
        "id": "fn_sensors",
        "type": "function",
        "z": "sim_tab",
        "name": "Емуляція датчиків",
        "func": "let soil = flow.get(\"soil\") || 50;\nlet temp = flow.get(\"temp\") || 22;\n\nsoil += (Math.random() - 0.5) * 15;\ntemp += (Math.random() - 0.5) * 1;\n\nsoil = Math.max(20, Math.min(90, soil));\ntemp = Math.max(15, Math.min(35, temp));\n\nflow.set(\"soil\", soil);\nflow.set(\"temp\", temp);\n\nmsg.payload = {\n    soil: Math.round(soil),\n    temperature: Math.round(temp)\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 470,
        "y": 120,
        "wires": [
            [
                "fn_split"
            ]
        ]
    },
    {
        "id": "fn_split",
        "type": "function",
        "z": "sim_tab",
        "name": "Розділення телеметрії",
        "func": "return [\n    { payload: msg.payload.soil },\n    { payload: msg.payload.temperature },\n    { payload: msg.payload }\n];",
        "outputs": 3,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 120,
        "wires": [
            [
                "g_moisture",
                "mqtt_m"
            ],
            [
                "g_temp",
                "mqtt_t"
            ],
            [
                "auto_water",
                "6c041a6bbe719517",
                "bf097d43585cab84"
            ]
        ]
    },
    {
        "id": "auto_water",
        "type": "function",
        "z": "sim_tab",
        "name": "Автополив",
        "func": "let soil = msg.payload.soil || msg.payload;\n\nif (soil < 30) {\n    msg.payload = \"🟢 Увімкнений\";\n} else {\n    msg.payload = \"🔴 Вимкнений\";\n}\n\nreturn msg;",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1030,
        "y": 120,
        "wires": [
            [
                "mqtt_valve",
                "g_valve"
            ],
            [
                "debug_events"
            ]
        ]
    },
