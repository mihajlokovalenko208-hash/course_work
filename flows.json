        "type": "function",
        "z": "sim_tab",
        "name": "function 4",
        "func": "let sent = flow.get(\"alertSent\") || false;\n\nif (msg.payload < 30 && !sent) {\n\n    flow.set(\"alertSent\", true);\n\n    msg.payload = {\n        content: `🚨 Увага! Вологість ґрунту становить ${msg.payload}%`\n    };\n\n    return msg;\n}\n\nif (msg.payload >= 30) {\n    flow.set(\"alertSent\", false);\n}\n\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
